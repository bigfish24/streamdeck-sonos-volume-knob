{
  "Name": "Sonos Volume Knob",
  "Version": "1.0.0.0",
  "Author": "Adam",
  "Description": "Local-network Sonos volume control with auto-discovery. Rotate to change volume, press to mute. Built for Stream Deck +.",
  "Category": "Sonos",
  "CategoryIcon": "imgs/actions/volume",
  "Icon": "imgs/plugin/icon",
  "CodePath": "bin/plugin.js",
  "SDKVersion": 2,
  "Software": { "MinimumVersion": "6.5" },
  "OS": [
    { "Platform": "mac", "MinimumVersion": "10.15" },
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Nodejs": { "Version": "20" },
  "Actions": [
    {
      "Name": "Sonos Volume",
      "UUID": "com.ditto.sonos.volume",
      "Icon": "imgs/actions/volume",
      "Tooltip": "Rotate to change volume, press to mute.",
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "$B1",
        "StackColor": "#1DB954",
        "TriggerDescription": {
          "Rotate": "Adjust volume",
          "Push": "Toggle mute",
          "Touch": "Toggle mute"
        }
      },
      "States": [
        { "Image": "imgs/actions/volume", "TitleAlignment": "middle" }
      ],
      "PropertyInspectorPath": "ui/inspector.html"
    }
  ]
}
